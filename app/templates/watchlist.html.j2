{% extends "base.html.j2" %}
{% block title %}监控列表 - CS2 Monitor{% endblock %}
{% block content %}
<h1>监控列表</h1>
<div class="card">
    <form method="post" action="/watchlist/add" style="display:flex;gap:8px;align-items:end;flex-wrap:wrap">
        <div><label>饰品名</label><input name="item_name" placeholder="如 AK-47 红线" required></div>
        <div><label>目标价 ¥</label><input name="target_price" type="number" step="0.01" required></div>
        <div><label>模式</label><select name="mode"><option value="1">盯价</option><option value="2">持仓</option></select></div>
        <button type="submit">添加监控</button>
    </form>
</div>
<table>
    <tr><th>饰品</th><th>目标价</th><th>模式</th><th>状态</th><th>操作</th></tr>
    {% for item in items %}
    <tr>
        <td>{{ item.market_hash_name }}</td>
        <td>{% if item.target_price %}¥{{ "%.2f"|format(item.target_price) }}{% else %}-{% endif %}</td>
        <td>{% if item.mode == 1 %}盯价{% elif item.mode == 2 %}持仓{% else %}扫描{% endif %}</td>
        <td>{% if item.enabled %}<span style="color:var(--green)">启用</span>{% else %}<span style="color:var(--red)">停用</span>{% endif %}</td>
        <td>
            <form method="post" action="/watchlist/{{ item.id }}/toggle" style="display:inline">
                <button type="submit">{% if item.enabled %}停用{% else %}启用{% endif %}</button>
            </form>
            <form method="post" action="/watchlist/{{ item.id }}/delete" style="display:inline">
                <button type="submit" class="danger">删除</button>
            </form>
        </td>
    </tr>
    {% else %}
    <tr><td colspan="5" style="text-align:center;color:#8b949e">暂无监控饰品，请在上方添加</td></tr>
    {% endfor %}
</table>
{% endblock %}
