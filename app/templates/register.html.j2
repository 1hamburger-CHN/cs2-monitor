{% extends "base.html.j2" %}
{% block title %}注册 - CS2 Monitor{% endblock %}
{% block content %}
<h1>注册</h1>
<div class="card">
    <form method="post">
        <p><input name="username" placeholder="用户名" required style="width:100%"></p>
        <p><input name="password" type="password" placeholder="密码" required style="width:100%"></p>
        <p><input name="invite_code" placeholder="邀请码" required style="width:100%"></p>
        <p><button type="submit">注册</button></p>
    </form>
    <p>已有账号？<a href="/login">登录</a></p>
</div>
{% endblock %}
