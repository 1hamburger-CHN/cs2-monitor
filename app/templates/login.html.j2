{% extends "base.html.j2" %}
{% block title %}登录 - CS2 Monitor{% endblock %}
{% block content %}
<h1>登录</h1>
<div class="card">
    <form method="post">
        <p><input name="username" placeholder="用户名" required style="width:100%"></p>
        <p><input name="password" type="password" placeholder="密码" required style="width:100%"></p>
        <p><button type="submit">登录</button></p>
    </form>
    <p>没有账号？<a href="/register">注册</a></p>
</div>
{% endblock %}
